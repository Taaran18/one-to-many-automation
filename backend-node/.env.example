# ─── Server ───────────────────────────────────────────────────────────────────
PORT=8000
NODE_ENV=development

# ─── Database (Supabase PostgreSQL) ───────────────────────────────────────────
# Transaction Pooler URL (port 6543) — used for runtime queries
# Dashboard → Project Settings → Database → Connection string → Transaction pooler
DATABASE_URL=postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1

# Direct connection URL (port 5432) — used only for Prisma migrations
# Dashboard → Project Settings → Database → Connection string → Direct connection
DIRECT_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# ─── Security ─────────────────────────────────────────────────────────────────
# MUST be the same value as SECRET_KEY in the FastAPI .env (same JWT signing key)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SECRET_KEY=your_secret_key_here

# MUST be the same value as ENCRYPTION_KEY in the FastAPI .env (same Fernet key)
# This decrypts all existing passwords and Meta tokens stored in the DB
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your_fernet_key_here

# ─── URLs ─────────────────────────────────────────────────────────────────────
# Your deployed backend URL (used to build uploaded image URLs returned to frontend)
BACKEND_URL=https://your-backend.onrender.com

# Your Vercel frontend URL (comma-separated if multiple origins)
ALLOWED_ORIGINS=https://your-app.vercel.app,http://localhost:3000

# Your WhatsApp bridge service URL
BRIDGE_URL=https://your-bridge.onrender.com
