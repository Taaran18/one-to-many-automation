# ─── Server ───────────────────────────────────────────────────────────────────
PORT=8000
NODE_ENV=development

# ─── Database (Supabase PostgreSQL) ───────────────────────────────────────────
# Transaction Pooler URL (port 6543) — used for runtime queries
# Dashboard → Project Settings → Database → Connection string → Transaction pooler
DATABASE_URL=postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1

# Direct connection URL (port 5432) — used only for Prisma migrations
# Dashboard → Project Settings → Database → Connection string → Direct connection
DIRECT_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# ─── Security ─────────────────────────────────────────────────────────────────
# MUST be the same value as SECRET_KEY in the FastAPI .env (same JWT signing key)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SECRET_KEY=your_secret_key_here

# MUST be the same value as ENCRYPTION_KEY in the FastAPI .env (same Fernet key)
# This decrypts all existing passwords and Meta tokens stored in the DB
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your_fernet_key_here

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# GCP → APIs & Services → Credentials → OAuth 2.0 Client IDs
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Must match exactly what's in GCP → Authorized redirect URIs
# Dev:  http://localhost:8000/auth/google/callback
# Prod: https://your-backend.railway.app/auth/google/callback
GOOGLE_CALLBACK_URL=http://localhost:8000/auth/google/callback

# Dev:  http://localhost:8000/email/google/callback
# Prod: https://your-backend.railway.app/email/google/callback
GOOGLE_EMAIL_CALLBACK_URL=http://localhost:8000/email/google/callback

# ─── URLs ─────────────────────────────────────────────────────────────────────
# Self-referential backend URL (used to build uploaded image URLs)
# Dev:  http://localhost:8000
# Prod: https://your-backend.railway.app  (or your custom domain)
BACKEND_URL=http://localhost:8000

# Frontend URL — used to redirect after Google OAuth
# Dev:  http://localhost:3000
# Prod: https://your-app.vercel.app  (or your custom domain)
FRONTEND_URL=http://localhost:3000

# Comma-separated list of allowed CORS origins
# Dev:  http://localhost:3000
# Prod: https://your-app.vercel.app,https://yourdomain.com
ALLOWED_ORIGINS=http://localhost:3000
