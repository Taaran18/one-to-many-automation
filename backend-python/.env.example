# ─── Database (Supabase / PostgreSQL) ────────────────────────────────────────
# Get from: Supabase Dashboard → Project Settings → General → Reference ID
# URL-encode special chars in password (spaces → %20)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# ─── Security ─────────────────────────────────────────────────────────────────
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_secret_key_here

# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your_fernet_key_here

# ─── URLs (production — set these on Render) ──────────────────────────────────
# Your own Render backend URL (used to build uploaded image URLs)
BACKEND_URL=https://onetomany-backend.onrender.com

# Your Vercel frontend URL (comma-separated if multiple)
ALLOWED_ORIGINS=https://your-app.vercel.app,http://localhost:3000

# Your Render WhatsApp bridge URL
BRIDGE_URL=https://onetomany-bridge.onrender.com

# ─── OAuth (optional) ────────────────────────────────────────────────────────
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# APPLE_CLIENT_ID=
# APPLE_CLIENT_SECRET=
# MICROSOFT_CLIENT_ID=
# MICROSOFT_CLIENT_SECRET=
