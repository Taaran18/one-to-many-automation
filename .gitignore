# ──────────────────────────────────────────────
# ONE-TO-MANY AUTOMATION — .gitignore
# ──────────────────────────────────────────────

# ─── Environment / Secrets ───────────────────
.env
.env.local
.env.*.local
backend/.env

# ─── Frontend (Next.js / Node) ───────────────
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/build/
frontend/.vercel/
frontend/npm-debug.log*
frontend/yarn-debug.log*
frontend/yarn-error.log*
frontend/.pnpm-debug.log*
frontend/.pnp.*
frontend/.eslintcache
frontend/tsconfig.tsbuildinfo

# ─── WhatsApp Bridge (Node / Express) ────────
whatsapp-bridge/node_modules/
whatsapp-bridge/sessions/          # Puppeteer/LocalAuth session data (contains credentials)
whatsapp-bridge/npm-debug.log*
whatsapp-bridge/yarn-debug.log*

# ─── Backend (Python / FastAPI) ──────────────
backend/__pycache__/
backend/**/__pycache__/
backend/*.py[cod]
backend/*$py.class
backend/venv/
backend/.venv/
backend/env/
backend/.env
backend/pip-log.txt
backend/pip-delete-this-directory.txt

# Scratch / dev-only scripts
backend/reset_db.py
backend/reset_db2.py

# ─── Database Files ───────────────────────────
*.sqlite3
*.db

# ─── OS / System Files ────────────────────────
.DS_Store
**/.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db
Desktop.ini

# ─── IDEs / Editors ───────────────────────────
.vscode/
.idea/
.claude/
*.swp
*.swo
*.suo
*.user
*.userosscache
*.sln.docstates

# ─── Logs ─────────────────────────────────────
logs/
*.log

# ─── Misc ────────────────────────────────────
.cache/
tmp/
