# ── Secrets ───────────────────────────────────────────────────────────────────
.env
.env.local
.env.*.local

# ── Frontend (Next.js) ────────────────────────────────────────────────────────
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/build/
frontend/.vercel/
frontend/npm-debug.log*
frontend/yarn-debug.log*
frontend/yarn-error.log*
frontend/.pnpm-debug.log*
frontend/.pnp.*
frontend/.eslintcache
frontend/tsconfig.tsbuildinfo

# ── Backend Node (Express + in-process bridges) ───────────────────────────────
backend-node/node_modules/
backend-node/npm-debug.log*
backend-node/yarn-debug.log*

# WhatsApp session data (Chrome profiles, auth tokens — never commit)
backend-node/wa-sessions/
backend-node/.cache/

# Email session credentials (contains plaintext SMTP passwords)
backend-node/email-sessions.json

# Uploaded files
backend-node/uploads/

# ── Backend Python (archived — kept for reference) ───────────────────────────
backend-python/__pycache__/
backend-python/**/__pycache__/
backend-python/*.py[cod]
backend-python/*$py.class
backend-python/venv/
backend-python/.venv/
backend-python/env/
backend-python/.env
backend-python/uploads/

# ── Database files ────────────────────────────────────────────────────────────
*.sqlite3
*.db

# ── OS / System ───────────────────────────────────────────────────────────────
.DS_Store
**/.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# ── IDEs / Editors ────────────────────────────────────────────────────────────
.vscode/
.idea/
.claude/
*.swp
*.swo
*.suo
*.user

# ── Logs ──────────────────────────────────────────────────────────────────────
logs/
*.log

# ── Misc ──────────────────────────────────────────────────────────────────────
tmp/
package-lock.json
