# ─── Database ─────────────────────────────────────────────────────────────────
# Production: Supabase connection string (overrides individual vars below)
# Get it from: Supabase → Project Settings → Database → Connection string (URI)
# Use the "Session pooler" URL for best compatibility with FastAPI
# DATABASE_URL=postgresql+psycopg2://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# Local development: MySQL (only used if DATABASE_URL is not set)
DB_USER=root
DB_PASSWORD=your_mysql_password_here
DB_HOST=localhost
DB_PORT=3306
DB_NAME=onetomany_db

# ─── Security ─────────────────────────────────────────────────────────────────
# Generate SECRET_KEY with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_secret_key_here

# Generate ENCRYPTION_KEY with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your_fernet_key_here

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated allowed frontend origins
# Production: add your Vercel URL
ALLOWED_ORIGINS=http://localhost:3000
# ALLOWED_ORIGINS=https://your-app.vercel.app,http://localhost:3000

# ─── WhatsApp Bridge ──────────────────────────────────────────────────────────
# Production: your Render bridge service URL
BRIDGE_URL=http://localhost:3001
# BRIDGE_URL=https://onetomany-bridge.onrender.com

# ─── OAuth (optional) ─────────────────────────────────────────────────────────
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# APPLE_CLIENT_ID=
# APPLE_CLIENT_SECRET=
# MICROSOFT_CLIENT_ID=
# MICROSOFT_CLIENT_SECRET=
